# =============================================================================
# Personalized News Aggregator — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/news_aggregator?schema=public"

# JWT signing secret — min 32 characters, random
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_hex_char_string

# AES-256-GCM key for encrypting Feedbin credentials.
# Must be exactly 32 raw bytes, stored here as base64 (will be 44 characters).
# Generate: openssl rand -base64 32
FEEDBIN_ENCRYPTION_KEY=

# Shared secret for admin ingest endpoints (X-Admin-Token header).
# Only needed on the server; never sent to end users.
# Generate: openssl rand -hex 32   (produces 64-char hex = 32 bytes)
ADMIN_TOKEN=change_me_to_64_hex_chars

# News API keys
CURRENTS_API_KEY=your_currents_api_key
GNEWS_API_KEY=your_gnews_api_key
NEWSDATA_API_KEY=your_newsdata_api_key

# Server config
PORT=3001
NODE_ENV=development
